              <calculation class='tableau' formula='DATEDIFF(&#13;&#10;    &apos;week&apos;,&#13;&#10;    { FIXED : MIN([week_start_date (demand!ts)]) },&#13;&#10;    [week_start_date (demand!ts)]&#13;&#10;)' />
